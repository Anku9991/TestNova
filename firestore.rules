rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function getUserRole() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc != null ? userDoc.data.role : 'student';
    }

    function isSuperAdmin() {
      return isAuthenticated() && (getUserRole() == 'super_admin' || getUserRole() == 'superadmin');
    }

    function isAdmin() {
      return isAuthenticated() && (getUserRole() == 'admin' || getUserRole() == 'super_admin' || getUserRole() == 'superadmin');
    }

    function isTeacher() {
      return isAuthenticated() && getUserRole() in ['teacher', 'admin', 'super_admin', 'superadmin'];
    }

    function isActiveUser() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return isAuthenticated() && userDoc != null && userDoc.data.isActive == true;
    }

    // ── Users collection ────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && (
        isOwner(userId) && !('role' in request.resource.data.diff(resource.data).affectedKeys()) ||
        isSuperAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // ── Exams collection ─────────────────────────────────────────────
    // BUG FIX: resource.data.isPublished only works for get, not list
    match /exams/{examId} {
      allow get: if resource.data.isPublished == true || isAdmin();
      allow list: if isAdmin() || isActiveUser();
      allow create: if isTeacher();
      allow update: if isTeacher();
      allow delete: if isAdmin();
    }

    // ── Academics Collections ───────────────────────────────────────
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // BUG FIX: Removed duplicate/conflicting subjects rule. One rule only.
    match /subjects/{subjectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /chapters/{chapterId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /topics/{topicId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Questions collection ─────────────────────────────────────────
    match /questions/{questionId} {
      allow read: if isActiveUser() || isAdmin();
      allow create: if isTeacher();
      allow update: if isTeacher();
      allow delete: if isAdmin();
    }

    // ── Attempts collection ─────────────────────────────────────────
    match /attempts/{attemptId} {
      allow get: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow list: if isAdmin();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid &&
        resource.data.isSubmitted == false
      );
      allow delete: if isSuperAdmin();
    }

    // ── Results collection ───────────────────────────────────────────
    match /results/{resultId} {
      allow get: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow list: if isAdmin() || isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    // ── Subscriptions collection ─────────────────────────────────────
    match /subscriptions/{subId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    // ── Categories (public read) ──────────────────────────────────────
    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Notifications ─────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        resource.data.userId == 'all' ||
        isAdmin()
      );
      allow create: if isAdmin();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ── Blogs (public read when published) ────────────────────────────
    match /blogs/{blogId} {
      allow get: if resource.data.isPublished == true || isAdmin();
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    // ── Support tickets ───────────────────────────────────────────────
    match /support_tickets/{ticketId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // ── Audit logs (super admin only) ────────────────────────────────
    match /auditLogs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isAdmin();
      allow update, delete: if false; // Immutable logs
    }

    // ── Plans (public read) ───────────────────────────────────────────
    match /plans/{planId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ── Coupons ───────────────────────────────────────────────────────
    match /coupons/{couponId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ── Banners (public read) ─────────────────────────────────────────
    match /banners/{bannerId} {
      allow get: if resource.data.isActive == true || isAdmin();
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    // ── Bookmarks ────────────────────────────────────────────────────
    // BUG FIX: Separated read/write rules properly
    match /bookmarks/{bookmarkId} {
      allow get: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // ── Exam Questions Mapping ────────────────────────────────────────
    match /exam_questions/{mappingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
