rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Profile photos
    match /users/{userId}/profile/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
                      request.auth.uid == userId &&
                      request.resource.size < 5 * 1024 * 1024 && // 5MB limit
                      request.resource.contentType.matches('image/.*');
    }

    // Question images (admin only write)
    match /questions/{questionId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
                      get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin', 'teacher'] &&
                      request.resource.size < 10 * 1024 * 1024; // 10MB limit
    }

    // Exam banners and thumbnails
    match /exams/{examId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null &&
                      get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin'];
    }

    // Blog images
    match /blogs/{blogId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null &&
                      get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin', 'content_manager'];
    }

    // Certificates (generated PDFs)
    match /certificates/{userId}/{fileName} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null; // Written by server functions
    }

    // Bulk imports (admin only)
    match /imports/{fileName} {
      allow read: if request.auth != null &&
                     get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin'];
      allow write: if request.auth != null &&
                      get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin'] &&
                      request.resource.size < 50 * 1024 * 1024; // 50MB limit
    }
  }
}
